<view class="qp">
  <view class="prog"><view class="progf" style="width:{{percent}}%"></view></view>
  <view class="ptxt">第 {{qidx+1}} / {{total}} 题</view>
  <view class="qt">{{qtext}}</view>
  <view wx:for="{{options}}" wx:key="value" class="opt {{selVal===item.value?'sel':''}}" bindtap="pick" data-val="{{item.value}}">{{item.label}}</view>
  <view class="btc">
    <button wx:if="{{qidx>0}}" class="bt2" bindtap="prev">← 上一题</button>
    <button class="bt1" bindtap="next" disabled="{{selVal===undefined}}">{{isLast?'生成清单':'下一题 →'}}</button>
  </view>
</view>
