.tp{padding:24rpx}
.th{padding:32rpx 20rpx}
.pn{font-size:40rpx;font-weight:bold}
.ps{font-size:28rpx;color:#888;margin-top:8rpx}
.ph{margin-bottom:24rpx}
.phd{display:flex;align-items:center;gap:16rpx;padding:16rpx 8rpx}
.pi{font-size:48rpx}
.pn2{font-size:32rpx;font-weight:bold}
.pt2{font-size:24rpx;color:#999}
.pc{display:flex;justify-content:space-between;align-items:center;padding:24rpx;background:#fff;border-radius:16rpx;margin-bottom:12rpx;border-left:6rpx solid #ccc}
.pc.dn{opacity:.5}
.ud{width:12rpx;height:12rpx;border-radius:50%;margin-right:16rpx;flex-shrink:0}
.ud.critical{background:#e74c3c}
.ud.high{background:#f39c12}
.ud.normal{background:#95a5a6}
.pi2{flex:1}
.pn3{font-size:30rpx}
.pw{font-size:24rpx;color:#999;margin-top:4rpx}
.ck{font-size:40rpx;color:#8b7e6a}
.btc{display:flex;flex-direction:column;gap:16rpx;padding:32rpx;margin-top:32rpx}
.bt1{width:100%;height:80rpx;line-height:80rpx;background:#8b7e6a;color:#fff;border-radius:40rpx;font-size:28rpx;border:none}
.bt2{width:100%;height:80rpx;line-height:80rpx;background:#fff;color:#8b7e6a;border:2rpx solid #8b7e6a;border-radius:40rpx;font-size:28rpx}
